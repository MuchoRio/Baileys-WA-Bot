# Google AI Studio Gemini API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# WhatsApp Owner JIDs (comma-separated list of allowed JIDs/LIDs)
# e.g. 6281234567890@s.whatsapp.net,1234567890@lid
OWNER_JID=

# Contact name mapping for personalization (JSON format)
CONTACTS_MAP={"6281234567890":"Rio","1234567890":"Rio"}
